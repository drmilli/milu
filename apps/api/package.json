{
  "name": "@milu/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run -w @milu/agent-core build",
    "dev": "tsx watch src/index.ts",
    "prebuild": "npm run -w @milu/agent-core build",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "NODE_PATH=./node_modules drizzle-kit push:pg",
    "db:studio": "NODE_PATH=./node_modules drizzle-kit studio"
  },
  "dependencies": {
    "@milu/agent-core": "0.1.0",
    "@neondatabase/serverless": "^0.9.0",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "eventemitter3": "^5.0.1",
    "express": "^4.19.0",
    "express-rate-limit": "^7.3.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "node-html-parser": "^7.1.0",
    "nodemailer": "^6.9.0",
    "pdf-parse": "^1.1.1",
    "pino": "^9.2.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^11.2.0",
    "sendchamp-sdk": "^1.1.0",
    "stripe": "^22.2.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.13.1",
    "ws": "^8.17.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/pino-http": "^5.8.4",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/ws": "^8.5.0",
    "drizzle-kit": "^0.20.14",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
