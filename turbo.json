{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "ADMIN_JWT_SECRET",
    "ANTHROPIC_API_KEY",
    "API_URL",
    "APP_URL",
    "AT_API_KEY",
    "AT_USERNAME",
    "BREVO_API_KEY",
    "BREVO_SENDER_EMAIL",
    "BREVO_SENDER_NAME",
    "BREVO_SMTP_HOST",
    "BREVO_SMTP_PASSWORD",
    "BREVO_SMTP_PORT",
    "BREVO_SMTP_USER",
    "CLOUDINARY_API_KEY",
    "CLOUDINARY_API_SECRET",
    "CLOUDINARY_CLOUD_NAME",
    "CORS_ORIGINS",
    "DATABASE_URL",
    "DEEPGRAM_API_KEY",
    "ELEVENLABS_API_KEY",
    "ELEVENLABS_VOICE_ID",
    "EMAIL_FROM",
    "EMAIL_PROVIDER",
    "GMAIL_APP_PASSWORD",
    "GMAIL_USER",
    "HUME_API_KEY",
    "INFOBIP_API_KEY",
    "INFOBIP_BASE_URL",
    "INFOBIP_WHATSAPP_SENDER",
    "JWT_SECRET",
    "NODE_ENV",
    "OPENAI_API_KEY",
    "PORT",
    "REDIS_URL",
    "SENDCHAMP_API_KEY",
    "SENDCHAMP_EMAIL_API_KEY",
    "SENDCHAMP_SENDER_EMAIL",
    "SENDCHAMP_SENDER_NAME",
    "SENDCHAMP_WHATSAPP_SENDER",
    "TWILIO_ACCOUNT_SID",
    "TWILIO_AUTH_TOKEN",
    "TWILIO_PHONE_NUMBER",
    "TWILIO_WHATSAPP_APPOINTMENT_CONFIRM_CONTENT_SID",
    "TWILIO_WHATSAPP_APPOINTMENT_REMINDER_CONTENT_SID",
    "TWILIO_WHATSAPP_BROADCAST_CONTENT_SID",
    "TWILIO_WHATSAPP_CALLBACK_REQUEST_CONTENT_SID",
    "TWILIO_WHATSAPP_ESCALATION_ALERT_CONTENT_SID",
    "TWILIO_WHATSAPP_FROM",
    "TWILIO_WHATSAPP_MISSED_CALL_CONTENT_SID",
    "TWILIO_WHATSAPP_NOTIFICATION_CONTENT_SID",
    "TWILIO_WHATSAPP_ORDER_CONFIRM_CONTENT_SID",
    "TWILIO_WHATSAPP_ORDER_STATUS_CONTENT_SID",
    "TWILIO_WHATSAPP_OTP_CONTENT_SID",
    "TWILIO_WHATSAPP_WEEKLY_SUMMARY_CONTENT_SID",
    "WHATSAPP_PHONE_ID",
    "WHATSAPP_TOKEN",
    "WHATSAPP_WEBHOOK_VERIFY_TOKEN",
    "WHOP_API_KEY",
    "WHOP_COMPANY_API_KEY",
    "WHOP_COMPANY_ID",
    "WHOP_WEBHOOK_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:unit": {},
    "test:integration": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
